# ─── Lab Environment Variables ───────────────────────────────────────────────
# Copy this file to .env and adjust values as needed.
# .env is gitignored and never committed.
#
# Usage: docker compose reads .env automatically.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Jupyter Server ───────────────────────────────────────────────────────────
# Leave empty for no token (local use only).
JUPYTER_TOKEN=local-dev

# ─── PostgreSQL (compose.orm.yml) ─────────────────────────────────────────────
POSTGRES_DB=northwind
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ─── Microsoft SQL Server (compose.sql.yml) ───────────────────────────────────
# Must be at least 8 characters with uppercase, lowercase, digit, and symbol.
SA_PASSWORD=61eF92j4VTtl
